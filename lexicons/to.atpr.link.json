{
  "lexicon": 1,
  "id": "to.atpr.link",
  "defs": {
    "main": {
      "type": "record",
      "description": "A shortened URL mapping",
      "key": "any",
      "record": {
        "type": "object",
        "required": ["url", "createdAt"],
        "properties": {
          "url": { "type": "string", "format": "uri", "maxLength": 2048 },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
